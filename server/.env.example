# Firebase 서비스 계정 키 파일 경로
FIREBASE_KEY_PATH=./firebase-key.json

# Firebase Storage 버킷 이름 (예: my-project.appspot.com)
FIREBASE_BUCKET=your-project-id.appspot.com

# CORS 허용 도메인 (쉼표로 구분)
# 로컬 개발 + Vercel 배포 도메인을 함께 등록
# 예: ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# 서버 포트
PORT=8080

# === 적대적 노이즈 (Stable Diffusion 기반) ===
# GPU가 있고 diffusers/torch가 설치된 환경에서만 1로 설정.
# CPU 전용 환경에선 0(또는 미설정) — 요청 시 자동으로 건너뜀.
AI_NOISE_ENABLED=0

# 모델 ID (Hugging Face 경로). 첫 호출 시 자동 다운로드 (~4GB).
SD_MODEL_ID=runwayml/stable-diffusion-v1-5

# PGD 스텝 수. 50이 시연용 균형. 30이면 빠르고 약함, 80이면 느리고 강함.
AI_NOISE_STEPS=50

# perturbation 상한(/255). 16이면 사람 눈엔 거의 안 보임.
AI_NOISE_EPS=16

# === TrustMark 학습 워터마크 (선택, GPU 환경) ===
# AI 재생성에도 메시지가 살아남는 학습 워터마크. 1로 켜면 DCT 워터마크 위에 추가 적용.
TRUSTMARK_ENABLED=0
# 'Q'(화질 우선, 기본) 또는 'B'(강건성 우선)
TRUSTMARK_MODEL_TYPE=Q

# === CLIP 의미 임베딩 (선택, GPU 환경) ===
# 픽셀이 다 바뀌어도 의미 비슷하면 매칭. 표절 검증(/api/verify)에 필수.
CLIP_ENABLED=0
CLIP_MODEL=ViT-L-14
CLIP_PRETRAINED=openai
